{
  "name": "@memory-river/core",
  "version": "0.2.0",
  "description": "Framework-neutral long-term memory engine for Node.js agents.",
  "private": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hsi431/memory-river.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Hsi431/memory-river#readme",
  "bugs": "https://github.com/Hsi431/memory-river/issues",
  "keywords": [
    "memory",
    "agent",
    "llm",
    "long-term-memory",
    "lancedb"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.mjs tests/*.test.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.14.0",
    "apache-arrow": "^18.1.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "onnxruntime-node": "1.14.0",
    "nodejieba": "^3.5.7"
  }
}
