{
  "name": "@memory-river/service",
  "version": "0.2.0",
  "description": "Loopback HTTP daemon for the Memory River core engine.",
  "private": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hsi431/memory-river.git",
    "directory": "packages/service"
  },
  "homepage": "https://github.com/Hsi431/memory-river#readme",
  "bugs": "https://github.com/Hsi431/memory-river/issues",
  "keywords": [
    "memory",
    "agent",
    "llm",
    "http",
    "daemon"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mr-serve": "./dist/cli.js",
    "mr": "./dist/mr-cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@memory-river/adapter-mcp": "0.2.0",
    "@memory-river/core": "0.2.0"
  }
}
