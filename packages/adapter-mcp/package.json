{
  "name": "@memory-river/adapter-mcp",
  "version": "0.1.0",
  "description": "MCP stdio adapter for the Memory River core engine.",
  "license": "Apache-2.0",
  "repository": "https://github.com/Hsi431/memory-river",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
