  "bin": {
    "memory-river-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@memory-river/core": "0.1.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "4.3.6"
  }
