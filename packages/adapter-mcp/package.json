{
  "name": "@memory-river/adapter-mcp",
  "version": "0.2.0",
  "description": "MCP stdio adapter for the Memory River core engine.",
  "private": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hsi431/memory-river.git",
    "directory": "packages/adapter-mcp"
  },
  "homepage": "https://github.com/Hsi431/memory-river#readme",
  "bugs": "https://github.com/Hsi431/memory-river/issues",
  "keywords": [
    "memory",
    "agent",
    "mcp",
    "llm",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "memory-river-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@memory-river/core": "0.2.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "4.3.6"
  }
}
